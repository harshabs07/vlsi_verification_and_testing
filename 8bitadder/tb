class transaction;
    rand bit [7:0] a;
    rand bit [7:0] b;
    bit [8:0] sum;
    function void display(string name);
        $display("[%s] A=%d , B=%d , Sum=%d", name, a, b, sum);
    endfunction
endclass

//`include "transaction.sv"
class generator;
    transaction tr;
    mailbox #(transaction) mbx;
    int count=10;
    function new(mailbox #(transaction) mbx);
        this.mbx=mbx;
    endfunction
    task run();
        repeat(count) begin
            tr=new();
            assert(tr.randomize());
            mbx.put(tr);
        end
    endtask
endclass

//`include "transaction.sv"
class driver;
    virtual adder_if vif;
    mailbox#(transaction) mbx;
    transaction tr;

    function new(virtual adder_if vif, mailbox #(transaction) mbx);
        this.vif=vif;
        this.mbx=mbx;
    endfunction

    task run();
        forever begin
            mbx.get(tr);
            vif.a <= tr.a;
            vif.b <= tr.b;
            tr.display("DRV");
            #10;
        end
    endtask
endclass

//`include "transaction.sv"
class monitor;
    virtual adder_if vif;
    mailbox #(transaction) mbx;
    transaction tr;

    function new(virtual adder_if vif, mailbox #(transaction) mbx);
        this.vif = vif;
        this.mbx = mbx;
    endfunction

    task run();
        forever begin
            #5;
            tr =new();
            tr.a = vif.a;
            tr.b = vif.b;
            tr.sum = vif.sum;
            mbx.put(tr);
            #5;
        end
    endtask
endclass

//`include "transaction.sv"
class scoreboard;
    mailbox #(transaction) mbx;
    transaction tr;
    function new(mailbox #(transaction) mbx);
        this.mbx=mbx;
    endfunction
    task run();
        forever begin
            mbx.get(tr);
            if (tr.sum==(16'(tr.a) + tr.b)) begin
                $display("[SCB] PASS",tr.a,tr.b,tr.sum);
            end else begin
                $display("[SCB] FAIL",tr.a,tr.b,tr.sum,16'(tr.a) + tr.b);
            end
        end
    endtask
endclass

`include "transaction.sv"
`include "generator.sv"
`include "scoreboard.sv"
`include "driver.sv"
`include "monitor.sv"
class environment;
    generator gen;
    driver drv;
    monitor mon;
    scoreboard scb;

    mailbox #(transaction) gen2drv;
    mailbox #(transaction) mon2scb;

    virtual adder_if vif; //static (hardware)
    function new(virtual adder_if vif);
        this.vif=vif;
        gen2drv=new();
        mon2scb=new();

        gen=new(gen2drv);
        drv=new(vif,gen2drv);
        mon=new(vif,mon2scb);
        scb=new(mon2scb);
    endfunction
    task test();
        fork
            gen.run();
            drv.run();
            mon.run();
            scb.run();
        join_any
    endtask
endclass

`include "adder_if.sv"
`include "environment.sv"
module top_dut;
    adder_if intf();
    adder dut(
        .a(intf.a),.b(intf.b),.sum(intf.sum)
        );
    environment env;
    initial begin
        env=new(intf);
        env.gen.count=20;
        env.test(); #100;
        $finish;
        end

endmodule

